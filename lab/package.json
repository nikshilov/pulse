{
  "name": "pulse-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Pulse Lab — a playground showing state-aware retrieval. Vanilla TS, no LLM, no auth. Flip a slider, see retrieval flip.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=esm --target=es2022 --minify --sourcemap --outfile=dist/app.js",
    "dev": "node ./dev-server.mjs",
    "watch": "esbuild src/main.ts --bundle --format=esm --target=es2022 --sourcemap --watch --outfile=dist/app.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
